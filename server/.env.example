# Copy to server/.env — the Anthropic SDK reads ANTHROPIC_API_KEY from the environment.
ANTHROPIC_API_KEY=sk-ant-...

# To route through the local LiteLLM Proxy (multi-provider; needed for the
# Gemini fallbacks in routing.ts): start it with `docker compose up litellm`
# and set:
# LLM_BASE_URL=http://localhost:4000
# GEMINI_API_KEY=...

# PORT=3001
